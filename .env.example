# SQLite local (dev). En producción: postgresql://USER:PASS@HOST:5432/DB
DATABASE_URL="file:./dev.db"

# Sal para hashear IP + huella (obligatorio en producción; rotar si se filtra).
IP_HASH_SALT=

# Sal para firmar desafíos anti-bot internos (suma matemática; sin reCAPTCHA).
CHALLENGE_HMAC_SECRET=

# Anti-spam: ventana en ms (default 600000 = 10 min)
# SPAM_WINDOW_MS=600000

# Máximo de publicaciones en la ventana antes de marcar ruido (default 25)
# SPAM_MAX_POSTS_PER_WINDOW=25

# Máximo de marcas distintas en la ventana antes de marcar ruido (default 50)
# SPAM_MAX_DISTINCT_COMPANIES=50

# Si se define, GET /api/analytics exige: Authorization: Bearer <valor>
# ANALYTICS_API_SECRET=

# Moderación con Claude (Anthropic) al publicar quejas: PII, personas, severidad, marca canónica.
# ANTHROPIC_API_KEY=
# Opcional: modelo Messages API (default: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=
# En desarrollo sin API: true = no llama a Claude (solo anti-spam por tasa)
# SKIP_COMPLAINT_MODERATION=false
